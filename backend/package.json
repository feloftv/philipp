{
  "name": "philipp-backend",
  "version": "1.0.2",
  "description": "Backend para Philipp - Extrae Videos de Youtube",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "pm2:start": "pm2 start ecosystem.config.js",
    "pm2:stop": "pm2 stop philipp",
    "pm2:restart": "pm2 restart philipp",
    "pm2:logs": "pm2 logs philipp",
    "pm2:delete": "pm2 delete philipp",
    "pm2:prod": "pm2 start ecosystem.config.js --env production"
  },
  "keywords": [
    "youtube",
    "subtitles",
    "download",
    "txt",
    "pdf"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.6.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "pdfkit": "^0.13.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.2"
  }
}
